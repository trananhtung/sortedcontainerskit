{
  "name": "sortedcontainerskit",
  "version": "0.1.0",
  "description": "Sorted containers: SortedList (with duplicates), SortedSet, SortedMap. O(log n) bisect, rank, floor/ceiling, range queries. Port of Python sortedcontainers. Zero dependencies, TypeScript.",
  "keywords": [
    "sorted",
    "sorted-list",
    "sorted-set",
    "sorted-map",
    "btree",
    "binary-search",
    "rank",
    "bisect",
    "sortedcontainers",
    "ordered",
    "zero-dependency",
    "typescript"
  ],
  "author": "trananhtung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trananhtung/sortedcontainerskit.git"
  },
  "homepage": "https://github.com/trananhtung/sortedcontainerskit#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
